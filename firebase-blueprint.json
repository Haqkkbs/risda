{
  "entities": {
    "Note": {
      "title": "Note",
      "description": "A project note or feedback item.",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "The content of the note."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the note was created."
        },
        "authorId": {
          "type": "string",
          "description": "The ID of the user who created the note."
        }
      },
      "required": ["text", "createdAt"]
    }
  },
  "firestore": {
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "Collection of project notes."
    }
  }
}
